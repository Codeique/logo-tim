# Railway environment variables
# Set these in the Railway dashboard under Variables

NODE_ENV=production

# Railway provides this automatically when you add a PostgreSQL service
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# Generate with: openssl rand -base64 48
JWT_SECRET=6e701d749eb63a1eb5bff7f4265c1beef4e8635ccd0485d2f98ca54c80d7ae45
JWT_REFRESH_SECRET=f8258b2d7756c15139a0d7d82cb8ff495ed4fbf7a781cedb6d58df5b7cab0d4c9c911f68e22d23edef365a9cbeafce4abb7102265999e13460e7682bd1792896

# Your Vercel frontend URL (used for CORS and Socket.io origin check)
FRONTEND_URL=https://your-app.vercel.app

# Railway assigns PORT automatically — leave blank or set to 3001
PORT=3001

# Restricts /ready and /metrics to internal network only
INTERNAL_ONLY=true

LOG_LEVEL=info
