generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  THERAPIST
  CHIEF_THERAPIST
  PATIENT
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum TransactionType {
  PAYMENT
  REFUND
  ADJUSTMENT
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String
  role         Role     @default(PATIENT)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  therapist    Therapist?
  patient      Patient?
  tokens       UserToken[]
  transactions Transaction[] @relation("CreatedByUser")
  auditLogs    AuditLog[]
}

model UserToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Therapist {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  firstName   String
  lastName    String
  email       String    @unique
  hourlyRate  Decimal   @default(0) @db.Decimal(10, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  rooms       Room[]    @relation("TherapistRooms")
  sessions    Session[]
  finance     Finance[]
  patients    Patient[]
}

model Patient {
  id                Int        @id @default(autoincrement())
  userId            Int?       @unique
  user              User?      @relation(fields: [userId], references: [id], onDelete: Restrict)
  firstName         String
  lastName          String
  nickname          String?
  birthDate         DateTime?
  phone             String?
  diagnosis         String?
  notes             String?
  sessionPrice      Decimal    @default(0) @db.Decimal(10, 2)
  accountBalance    Decimal    @default(0) @db.Decimal(10, 2)
  remainingSessions Int        @default(0)
  isActive          Boolean    @default(true)
  isMilitary        Boolean    @default(false)
  nationalId        String?
  insuranceHolder   String?
  medicalFileNumber String?
  militaryPost      String?
  primaryTherapistId Int?
  primaryTherapist   Therapist? @relation(fields: [primaryTherapistId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  sessions         Session[]
  transactions     Transaction[]
  evaluations      Evaluation[]
  militaryRequests MilitaryRequest[]

  @@index([firstName, lastName])
  @@index([phone])
  @@index([nationalId])
}

model Room {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  therapists Therapist[] @relation("TherapistRooms")
  sessions   Session[]
}

model Session {
  id            Int           @id @default(autoincrement())
  patientId     Int
  patient       Patient       @relation(fields: [patientId], references: [id])
  therapistId   Int
  therapist     Therapist     @relation(fields: [therapistId], references: [id])
  roomId        Int?
  room          Room?         @relation(fields: [roomId], references: [id])
  date          DateTime
  startTime     DateTime
  duration      Int           // minutes
  status        SessionStatus @default(SCHEDULED)
  treatmentType String?
  isPaid        Boolean       @default(false)
  report        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  finance Finance?

  @@index([date])
  @@index([status, date])
  @@index([therapistId, date])
  @@index([patientId])
  @@index([roomId, date])
  @@index([status])
}

model Transaction {
  id          Int      @id @default(autoincrement())
  patientId   Int
  patient     Patient  @relation(fields: [patientId], references: [id])
  amount      Decimal         @db.Decimal(10, 2)
  type        TransactionType @default(PAYMENT)
  note        String?
  createdById Int
  createdBy   User     @relation("CreatedByUser", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([patientId])
  @@index([createdAt])
}

model Evaluation {
  id              Int      @id @default(autoincrement())
  patientId       Int
  patient         Patient  @relation(fields: [patientId], references: [id])
  date            DateTime
  content         String
  therapyProposal String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
  @@index([patientId, date])
}

model MilitaryRequest {
  id            Int      @id @default(autoincrement())
  patientId     Int
  patient       Patient  @relation(fields: [patientId], references: [id])
  requestNumber String   @unique
  totalSessions Int      @default(0)
  usedSessions  Int      @default(0)
  validFrom     DateTime
  validUntil    DateTime
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId])
  @@index([patientId, validFrom, validUntil])
}

model Finance {
  id               Int       @id @default(autoincrement())
  sessionId        Int       @unique
  session          Session   @relation(fields: [sessionId], references: [id])
  therapistId      Int
  therapist        Therapist @relation(fields: [therapistId], references: [id])
  therapistEarning Decimal   @db.Decimal(10, 2)
  companyIncome    Decimal   @db.Decimal(10, 2)
  createdAt        DateTime  @default(now())

  @@index([therapistId])
  @@index([createdAt])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  Int?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}
