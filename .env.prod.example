# VPS production environment variables
# Copy to .env on the server: cp .env.prod.example .env
# Then fill in all values — never commit the real .env

# PostgreSQL password (used by both db and backend services)
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=

# JWT signing secrets — must be different, 32+ characters each
# Generate: openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=

# Your domain (e.g. logotim.example.com) — must match the SSL cert
FRONTEND_URL=https://your-domain.com
DOMAIN=your-domain.com

NODE_ENV=production
LOG_LEVEL=info
