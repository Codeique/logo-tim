# Copy to .env and fill in values

# Backend
DATABASE_URL="postgresql://postgres:password@localhost:5432/logotim"
JWT_SECRET=
JWT_REFRESH_SECRET=
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
INTERNAL_ONLY=false

# Docker Compose (used by docker-compose.yml and docker-compose.prod.yml)
POSTGRES_PASSWORD=change-this-password
